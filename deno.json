{
  "name": "@bepalo/query",
  "version": "2.3.9",
  "exports": {
    ".": "./mod.ts",
    "./client": "./src/client.ts",
    "./mod.ts": "./mod.ts"
  },
  "description": "A type-safe access-control-driven unified RESTful database query engine for backend using Drizzle ORM.",
  "license": "MIT",
  "homepage": "https://github.com/bepalo/query",
  "repository": {
    "type": "git",
    "url": "https://github.com/bepalo/query"
  },
  "compilerOptions": {
    "strict": true
  },
  "lint": {
    "include": ["./src/", "./tests/"],
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-sloppy-imports", "no-explicit-any"]
    }
  },
  "fmt": {
    "include": ["./src/", "./tests/"],
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve"
  },
  "test": {
    "files": {
      "exclude": ["tests/**", "**/*.vitest.ts"]
    }
  },
  "imports": {},
  "keywords": [
    "query",
    "endpoint",
    "API",
    "REST",
    "router",
    "request",
    "response",
    "server"
  ]
}
