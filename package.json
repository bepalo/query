{
  "name": "@bepalo/query",
  "version": "2.3.8",
  "description": "A type-safe access-control-driven unified RESTful database query engine for backend using Drizzle ORM.",
  "author": "Natnael Eshetu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bepalo/query.git"
  },
  "homepage": "https://github.com/bepalo/query#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/cjs/client.js"
    },
    "./src": {
      "import": "./src/index.ts"
    },
    "./src/*": {
      "import": "./src/*"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build": "concurrently \"pnpm run build:esm\" \"pnpm run build:cjs\"",
    "build:watch": "concurrently \"tsc --watch --project tsconfig.esm.json\" \"tsc --watch --project tsconfig.cjs.json\"",
    "prepublishOnly": "pnpm run build",
    "test": "vitest --reporter=dot",
    "test:ci": "vitest run --reporter=vitest-markdown-reporter --outputFile=test-result.md"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6",
    "vitest-markdown-reporter": "^0.1.2"
  },
  "keywords": [
    "query",
    "endpoint",
    "API",
    "REST",
    "router",
    "request",
    "response",
    "server"
  ],
  "dependencies": {
    "@bepalo/rjson": "^2.1.11",
    "arktype": "^2.2.0",
    "drizzle-orm": "^0.45.2"
  }
}
